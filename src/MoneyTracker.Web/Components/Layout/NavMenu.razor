        <div class="nav-brand-name">MoneyTracker</div>
        <div class="nav-brand-sub">個人收支管理</div>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column">
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-ico">📊</span> 收支概覽
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="transactions">
                <span class="nav-ico">📒</span> 我的帳本
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="add">
                <span class="nav-ico">➕</span> 新增收支
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="categories">
                <span class="nav-ico">🏷️</span> 類別管理
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="budgets">
                <span class="nav-ico">💵</span> 預算管理
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="recurring">
                <span class="nav-ico">🔁</span> 週期性收支
            </NavLink>
        </div>
    </nav>
</div>

<div class="nav-footer">
    <AuthorizeView>
        <Authorized>
            <div class="nav-user">
                <span class="nav-user-avatar">@(GetInitial(context.User.Identity?.Name))</span>
                <span class="nav-user-name">@context.User.Identity?.Name</span>
            </div>
            <a class="nav-logout" href="/Identity/Account/Logout">登出</a>
        </Authorized>
        <NotAuthorized>
            <a class="nav-logout" href="/Identity/Account/Login">登入</a>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private static string GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        return name.Trim()[..1].ToUpperInvariant();
    }
}
